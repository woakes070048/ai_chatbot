   "options": "\nMonday\nTuesday\nWednesday\nThursday\nFriday\nSaturday\nSunday"
  },
  {
   "depends_on": "eval:doc.schedule=='Monthly'",
   "description": "1\u201328. Use 1 for the first of the month.",
   "fieldname": "day_of_month",
   "fieldtype": "Int",
   "label": "Day of Month"
  },
  {
   "depends_on": "eval:doc.schedule=='Custom Cron'",
